    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u0412\u0435\u043B\u0435\u043C\u0430\u0440: \u0434\u0435\u0440\u0435\u0432\u043D\u044F
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435, \u0421\u0442\u0430\u0440\u044B\u0439
    \u041B\u0435\u0441 \u043D\u0430 \u0437\u0430\u043F\u0430\u0434\u0435, \u0427\u0451\u0440\u043D\u043E\u0435
    \u0411\u043E\u043B\u043E\u0442\u043E \u043D\u0430 \u044E\u0433\u0435, \u041F\u0435\u043F\u0435\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0430\u043A\u0442 \u043D\u0430 \u0432\u043E\u0441\u0442\u043E\u043A\u0435,
    \u0440\u0443\u0438\u043D\u044B \u0431\u0430\u0448\u043D\u0438 \u043D\u0430 \u0441\u0435\u0432\u0435\u0440\u0435."
