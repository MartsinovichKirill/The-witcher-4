MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 682339113}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 48fdfcc8a67199e4aa51c8e7b7b14715, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WitcherRightVersion.Dialogue.DialogueInteractable
  displayName: Boris the Smith
  interactionPrompt: Talk
  startNodeId: start
  returnToElderNodeId: 
  completedQuestNodeId: 
  dialogueNodes:
  - Id: start
    SpeakerName: Boris the Smith
    Body: If the swamp chews your armor, do not blame the armor. Blame the witcher
      who walked in underprepared.
    Choices:
    - Text: Need work done?
      NextNodeId: debt
      FlagToSet: 
      QuestAction: start_smith_debt
      ClosesDialogue: 0
    - Text: I brought the old camp blade.
      NextNodeId: return
      FlagToSet: 
      QuestAction: smith_debt_returned
      ClosesDialogue: 0
    - Text: Later.
      NextNodeId: 
      FlagToSet: 
      QuestAction: 
      ClosesDialogue: 1
  - Id: debt
    SpeakerName: Boris the Smith
    Body: There is an old blade in the forest camp. Bring it back and I will reforge
      steel worth carrying.
    Choices:
    - Text: I will look for it.
      NextNodeId: 
      FlagToSet: 
      QuestAction: 
      ClosesDialogue: 1
  - Id: return
    SpeakerName: Boris the Smith
    Body: Good metal remembers hands better than people do. Take the improved steel
      sword.
    Choices:
    - Text: Fair trade.
      NextNodeId: 
      FlagToSet: 
      QuestAction: 
      ClosesDialogue: 1
