--- !u!114 &1282276677
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1282276675}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 48fdfcc8a67199e4aa51c8e7b7b14715, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WitcherRightVersion.Dialogue.DialogueInteractable
  displayName: Ivar Sedoy
  interactionPrompt: Talk
  startNodeId: start
  returnToElderNodeId: 
  completedQuestNodeId: 
  dialogueNodes:
  - Id: start
    SpeakerName: Ivar Sedoy
    Body: 'If you came for the hunter, you found what is left of him: a man who learned
      the forest is quieter than the village.'
    Choices:
    - Text: I can still use your eyes on the Ash Road.
      NextNodeId: ally
      FlagToSet: IvarSaved
      QuestAction: 
      ClosesDialogue: 0
    - Text: Stay hidden then.
      NextNodeId: 
      FlagToSet: 
      QuestAction: 
      ClosesDialogue: 1
  - Id: ally
    SpeakerName: Ivar Sedoy
    Body: Then I owe you one shot when the elder's people raise their bows.
    Choices:
    - Text: I will remember that.
      NextNodeId: 
      FlagToSet: 
      QuestAction: 
      ClosesDialogue: 1
