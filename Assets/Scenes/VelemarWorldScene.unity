  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WitcherRightVersion.Dialogue.DialogueInteractable
  displayName: Elsa Cherntravka
  interactionPrompt: Talk
  startNodeId: start
  returnToElderNodeId: 
  completedQuestNodeId: 
  dialogueNodes:
  - Id: start
    SpeakerName: Elsa Cherntravka
    Body: You chose a witness over comfort, witcher. The old road remembers that.
      I can steady the rite, but I cannot choose for you.
    Choices:
    - Text: Stay near the altar.
      NextNodeId: 
      FlagToSet: 
      QuestAction: 
      ClosesDialogue: 1
