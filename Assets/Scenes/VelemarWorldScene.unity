  m_EditorClassIdentifier: Assembly-CSharp::WitcherRightVersion.Dialogue.DialogueInteractable
  displayName: Ivar Sedoy
  interactionPrompt: Talk
  startNodeId: start
  returnToElderNodeId: 
  completedQuestNodeId: 
  dialogueNodes:
  - Id: start
    SpeakerName: Ivar Sedoy
    Body: You pulled me out when the forest wanted payment. I owe you one clean shot
      if Voytsekh's men try to make this ugly.
    Choices:
    - Text: Watch the road.
      NextNodeId: 
      FlagToSet: 
      QuestAction: 
      ClosesDialogue: 1
